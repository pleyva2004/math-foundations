  {"id": "inverse", "symbol": "f⁻¹", "latex": "f^{-1}", "category": "functions", "read_as": "f inverse", "plain_english": "The inverse function (when bijective): f⁻¹(f(x)) = x. Also denotes preimage of a set.", "first_seen_in": "00-sets-and-functions", "examples": ["f^{-1}(B) = \\{x : f(x) \\in B\\}"]},
  {"id": "id", "symbol": "id_A", "latex": "\\mathrm{id}_A", "category": "functions", "read_as": "identity on A", "plain_english": "The function that sends every element of A to itself.", "first_seen_in": "00-sets-and-functions", "examples": ["\\mathrm{id}_A(x) = x"]},
  {"id": "dom", "symbol": "dom(f)", "latex": "\\mathrm{dom}(f)", "category": "functions", "read_as": "domain of f", "plain_english": "The set of inputs on which f is defined.", "first_seen_in": "00-sets-and-functions", "examples": ["\\mathrm{dom}(f) = A"]},
  {"id": "cod", "symbol": "cod(f)", "latex": "\\mathrm{cod}(f)", "category": "functions", "read_as": "codomain of f", "plain_english": "The declared target set of f (not necessarily its image).", "first_seen_in": "00-sets-and-functions", "examples": ["\\mathrm{cod}(f) = B"]},
