  {"id": "subseteq", "symbol": "⊆", "latex": "\\subseteq", "category": "sets", "read_as": "is a subset of (or equal)", "plain_english": "A ⊆ B means every element of A is in B; equality allowed.", "first_seen_in": "00-sets-and-functions", "examples": ["A \\subseteq A"]},
  {"id": "supseteq", "symbol": "⊇", "latex": "\\supseteq", "category": "sets", "read_as": "is a superset of (or equal)", "plain_english": "A ⊇ B is the reverse of B ⊆ A.", "first_seen_in": "00-sets-and-functions", "examples": ["\\mathbb{R} \\supseteq \\mathbb{Q}"]},
