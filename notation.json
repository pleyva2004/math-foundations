  {"id": "cartesian", "symbol": "×", "latex": "\\times", "category": "sets", "read_as": "Cartesian product", "plain_english": "A × B is the set of ordered pairs (a, b) with a ∈ A, b ∈ B.", "first_seen_in": "00-sets-and-functions", "examples": ["\\mathbb{R} \\times \\mathbb{R} = \\mathbb{R}^2"]},
  {"id": "cardinality", "symbol": "|·|", "latex": "|S|", "category": "sets", "read_as": "cardinality / size of", "plain_english": "Number of elements of a (finite) set S; more generally, its cardinal.", "first_seen_in": "02-counting", "examples": ["|\\{a,b,c\\}| = 3"]},
  {"id": "powerset", "symbol": "𝒫(·)", "latex": "\\mathcal{P}(S)", "category": "sets", "read_as": "power set of", "plain_english": "The set of all subsets of S. |𝒫(S)| = 2^{|S|} for finite S.", "first_seen_in": "02-counting", "examples": ["\\mathcal{P}(\\{a,b\\}) = \\{\\emptyset, \\{a\\}, \\{b\\}, \\{a,b\\}\\}"]},
  {"id": "set-builder", "symbol": "{ x : P(x) }", "latex": "\\{x : P(x)\\}", "category": "sets", "read_as": "the set of x such that P(x)", "plain_english": "Set-builder notation: the set of all x satisfying property P(x). Read aloud as 'the set of x such that P of x'. The colon (or sometimes the vertical bar |) separates the variable from the defining condition. Without set-builder syntax, infinite sets like {x : x > 0} could not be written down at all -- roster notation {x_1, x_2, ...} relies on a pattern the reader can extrapolate, but set-builder makes the membership rule explicit.", "first_seen_in": "00-sets-and-functions", "examples": ["\\{x \\in \\mathbb{N} : x > 5\\}", "\\{x \\in \\mathbb{R} : x^2 < 2\\}", "\\{(x, y) \\in \\mathbb{R}^2 : x^2 + y^2 = 1\\}"]},
  {"id": "set-builder-restricted", "symbol": "{ x in S : P(x) }", "latex": "\\{x \\in S : P(x)\\}", "category": "sets", "read_as": "the set of x in S such that P of x", "plain_english": "Restricted set-builder notation: the subset of S consisting of those elements satisfying P. This is the form actually used in working mathematics, because membership questions are decidable only when the parent set S is given (otherwise '{x : x \\notin x}' yields Russell's paradox). When S is clear from context it is often omitted.", "first_seen_in": "00-sets-and-functions", "examples": ["\\{n \\in \\mathbb{N} : n \\text{ prime}\\}", "\\{f \\in C([0,1]) : f(0) = 0\\}", "\\{A \\subseteq \\Omega : \\mathbb{P}(A) > \\tfrac{1}{2}\\}"]},
  {"id": "binom", "symbol": "C(n,k)", "latex": "\\binom{n}{k}", "category": "sets", "read_as": "n choose k", "plain_english": "Number of k-element subsets of an n-element set.", "first_seen_in": "02-counting", "examples": ["\\binom{n}{k} = \\frac{n!}{k!(n-k)!}"]},

  {"id": "function", "symbol": "f: A → B", "latex": "f : A \\to B", "category": "functions", "read_as": "f from A to B", "plain_english": "A function f with domain A and codomain B; for every a ∈ A there is a unique f(a) ∈ B.", "first_seen_in": "00-sets-and-functions", "examples": ["f : \\mathbb{R} \\to \\mathbb{R},\\ f(x) = x^2"]},
  {"id": "mapsto", "symbol": "↦", "latex": "\\mapsto", "category": "functions", "read_as": "maps to", "plain_english": "Specifies the action of a function on an element. x ↦ f(x).", "first_seen_in": "00-sets-and-functions", "examples": ["x \\mapsto x^2"]},
